# ============================================================
# Project Tracker — Environment Variables
# ============================================================
# 1. Copy this file:   cp .env.local.example .env.local
# 2. Fill in the values below.
# 3. Never commit .env.local — it is already in .gitignore.
#
# Required variables are marked [REQUIRED].
# Optional variables can be left blank to disable that feature.
# ============================================================


# ── SUPABASE [REQUIRED] ──────────────────────────────────────
# Create a free project at https://supabase.com
# Find these in: Project Settings → API

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# Service role key — server-side only, never exposed to the browser.
# Used for admin operations (e.g. deleting accounts).
# Find it in: Project Settings → API → service_role (secret)
SUPABASE_SERVICE_KEY=[YOUR-SERVICE-ROLE-KEY]


# ── AI PROVIDERS ─────────────────────────────────────────────
# At least one AI provider key is needed to use the AI Chat and
# report generation features. Users can switch providers in Settings.
# Leave unused providers blank.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# OpenRouter (access many models via one key) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cohere (used for embeddings / knowledge base search)
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=


# ── EMAIL / PASSWORD RESET (Optional) ────────────────────────
# Required only if you want password-reset emails to work.
# Sign up at https://resend.com, create an API key, then configure
# Supabase custom SMTP (see SUPABASE_SETUP.md → Step 4).

RESEND_API_KEY=


# ── SITE ACCESS GATE (Optional — for private/owner-only deployments) ──
# When set, the entire site is locked behind a secret cookie.
# To unlock your browser: visit /api/unlock?secret=YOUR_VALUE
# To revoke someone's access: change this value and redeploy.
# Leave blank to disable the gate (standard self-hosted setup).
SITE_ACCESS_SECRET=

# ── BOT PROTECTION (Optional — recommended for public deployments) ──
# Cloudflare Turnstile protects login/signup from bots.
# Leave both blank to disable it entirely (fine for local/private use).
# Sign up at https://dash.cloudflare.com → Turnstile

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
